local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

-- ==========================================
-- 1. GUI 기존 개체 제거 및 저장소 설정
-- ==========================================
local GUI_NAME = "RivalsBodySpinGui"
local parentGui = (gethui and gethui()) or LocalPlayer:WaitForChild("PlayerGui")

if parentGui:FindFirstChild(GUI_NAME) then
    parentGui[GUI_NAME]:Destroy()
end

-- ==========================================
-- 2. 상태 변수 및 캐릭터 참조 캐싱
-- ==========================================
local neckPitch = 0
local waistPitch = 0
local spinSpeed = 90
local isRandomMode = false
local isSpinMode = false

local lastRandomTick = 0
local RANDOM_INTERVAL = 0.05

-- 캐릭터 파트 캐싱
local char, hum, hrp, neck, waist
local origNeckC0, origWaistC0

local function cacheCharacter(character)
    if not character then return end
    char = character
    hum = char:WaitForChild("Humanoid", 5)
    hrp = char:WaitForChild("HumanoidRootPart", 5)

    local head = char:WaitForChild("Head", 5)
    local upperTorso = char:WaitForChild("UpperTorso", 5)

    neck = head and head:FindFirstChild("Neck")
    waist = upperTorso and upperTorso:FindFirstChild("Waist")

    if neck then origNeckC0 = neck.C0 end
    if waist then origWaistC0 = waist.C0 end
    
    if hum and isSpinMode then
        hum.AutoRotate = false
    end
end

if LocalPlayer.Character then cacheCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(cacheCharacter)

-- ==========================================
-- 3. UI 생성 및 컴포넌트 헬퍼
-- ==========================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = GUI_NAME
screenGui.ResetOnSpawn = false
screenGui.Parent = parentGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 260, 0, 300)
mainFrame.Position = UDim2.new(0.05, 0, 0.25, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.BackgroundTransparency = 1
title.Text = "Pro CFrame & Spin Controller"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextSize = 13
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

-- 창 드래그 로직 (간결화)
local draggingWindow, dragStart, startPos
title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingWindow = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

-- UI 유틸리티 함수
local function createButton(text, yPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 26)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = text
    btn.Parent = mainFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 4)
    btnCorner.Parent = btn

    return btn
end

local function createSlider(yPos, labelText, defaultRatio, fillColor)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.9, 0, 0, 42)
    container.Position = UDim2.new(0.05, 0, 0, yPos)
    container.BackgroundTransparency = 1
    container.Parent = mainFrame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 16)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.TextSize = 11
    label.Font = Enum.Font.Gotham
    label.Parent = container

    local bgBar = Instance.new("Frame")
    bgBar.Size = UDim2.new(1, 0, 0, 10)
    bgBar.Position = UDim2.new(0, 0, 0, 20)
    bgBar.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    bgBar.BorderSizePixel = 0
    bgBar.Parent = container

    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(1, 0)
    bgCorner.Parent = bgBar

    local fillBar = Instance.new("Frame")
    fillBar.Size = UDim2.new(defaultRatio, 0, 1, 0)
    fillBar.BackgroundColor3 = fillColor or Color3.fromRGB(0, 170, 255)
    fillBar.BorderSizePixel = 0
    fillBar.Parent = bgBar

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(1, 0)
    fillCorner.Parent = fillBar

    local trigger = Instance.new("TextButton")
    trigger.Size = UDim2.new(1, 0, 1, 8)
    trigger.Position = UDim2.new(0, 0, 0, -4)
    trigger.BackgroundTransparency = 1
    trigger.Text = ""
    trigger.Parent = bgBar

    return trigger, bgBar, fillBar, label
end

-- 엘리먼트 생성
local randomButton = createButton("Waist Random: OFF", 35)
local spinButton = createButton("Body Spin Mode: OFF", 65)

local neckTrig, neckBg, neckFill, neckLbl = createSlider(98, "Neck Pitch: 0°", 0.5)
local waistTrig, waistBg, waistFill, waistLbl = createSlider(148, "Waist Pitch: 0°", 0.5, Color3.fromRGB(255, 100, 100))
local spinTrig, spinBg, spinFill, spinLbl = createSlider(198, "Spin Speed: 90", 0.5, Color3.fromRGB(150, 255, 100))

-- ==========================================
-- 4. 토글 및 슬라이더 통합 입력 핸들러
-- ==========================================
randomButton.MouseButton1Click:Connect(function()
    isRandomMode = not isRandomMode
    randomButton.Text = "Waist Random: " .. (isRandomMode and "ON" or "OFF")
    randomButton.BackgroundColor3 = isRandomMode and Color3.fromRGB(0, 120, 200) or Color3.fromRGB(60, 60, 75)
end)

spinButton.MouseButton1Click:Connect(function()
    isSpinMode = not isSpinMode
    spinButton.Text = "Body Spin Mode: " .. (isSpinMode and "ON" or "OFF")
    spinButton.BackgroundColor3 = isSpinMode and Color3.fromRGB(0, 180, 100) or Color3.fromRGB(60, 60, 75)
    if hum then hum.AutoRotate = not isSpinMode end
end)

-- 슬라이더 처리 최적화
local activeSlider = nil

local function registerSlider(trigger, bg, fill, label, minVal, maxVal, callback)
    trigger.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            activeSlider = { bg = bg, fill = fill, label = label, min = minVal, max = maxVal, cb = callback }
            
            -- 즉시 반영
            local relX = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            fill.Size = UDim2.new(relX, 0, 1, 0)
            local val = math.floor(minVal + (maxVal - minVal) * relX)
            callback(val, label)
        end
    end)
end

registerSlider(neckTrig, neckBg, neckFill, neckLbl, -180, 180, function(val, lbl)
    neckPitch = val
    lbl.Text = string.format("Neck Pitch: %d°", val)
end)

registerSlider(waistTrig, waistBg, waistFill, waistLbl, -180, 180, function(val, lbl)
    if not isRandomMode then
        waistPitch = val
        lbl.Text = string.format("Waist Pitch: %d°", val)
    end
end)

registerSlider(spinTrig, spinBg, spinFill, spinLbl, 0, 180, function(val, lbl)
    spinSpeed = val
    lbl.Text = string.format("Spin Speed: %d", val)
end)

-- 글로벌 InputChanged 및 InputEnded 단일 처리
UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if draggingWindow then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        elseif activeSlider then
            local relX = math.clamp((input.Position.X - activeSlider.bg.AbsolutePosition.X) / activeSlider.bg.AbsoluteSize.X, 0, 1)
            activeSlider.fill.Size = UDim2.new(relX, 0, 1, 0)
            local val = math.floor(activeSlider.min + (activeSlider.max - activeSlider.min) * relX)
            activeSlider.cb(val, activeSlider.label)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingWindow = false
        activeSlider = nil
    end
end)

-- ==========================================
-- 5. 메인 루프 (렌더링 최적화)
-- ==========================================
RunService.RenderStepped:Connect(function(dt)
    if not char or not char.Parent then return end

    -- 1) 전체 몸체 스핀
    if isSpinMode and hrp then
        local rotRad = math.rad(spinSpeed * (dt * 60))
        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, rotRad, 0)
    end

    -- 2) 목 CFrame
    if neck and origNeckC0 then
        neck.C0 = origNeckC0 * CFrame.Angles(math.rad(neckPitch), 0, 0)
    end

    -- 3) 허리 CFrame 및 난수 처리
    if waist and origWaistC0 then
        if isRandomMode then
            local now = tick()
            if now - lastRandomTick >= RANDOM_INTERVAL then
                lastRandomTick = now
                waistPitch = math.random(-180, 180)
                waistLbl.Text = string.format("Waist TP Random: %d°", waistPitch)
            end
        end
        waist.C0 = origWaistC0 * CFrame.Angles(math.rad(waistPitch), 0, 0)
    end
end)
