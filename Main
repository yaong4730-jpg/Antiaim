local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- 기존 GUI 정리
if game:GetService("CoreGui"):FindFirstChild("RivalsIkTest3Gui") then
    game:GetService("CoreGui").RivalsIkTest3Gui:Destroy()
end

local pitchAngle = 0
local isRandomMode = false
local ikControl = nil
local ikTargetPart = nil

local function setupIK(character)
    local humanoid = character:WaitForChild("Humanoid", 5)
    local upperTorso = character:WaitForChild("UpperTorso", 5)
    local rootPart = character:WaitForChild("HumanoidRootPart", 5)
    if not humanoid or not upperTorso or not rootPart then return end

    if ikTargetPart then ikTargetPart:Destroy() end
    if ikControl then ikControl:Destroy() end

    -- 1) IK 타깃 역할을 할 투명 파트 생성
    ikTargetPart = Instance.new("Part")
    ikTargetPart.Name = "IKTarget3"
    ikTargetPart.Size = Vector3.new(0.2, 0.2, 0.2)
    ikTargetPart.Transparency = 1
    ikTargetPart.CanCollide = false
    ikTargetPart.Anchored = true
    ikTargetPart.Parent = character

    -- 2) IKControl 생성
    ikControl = Instance.new("IKControl")
    ikControl.Name = "WaistIK_LookAt"
    ikControl.Type = Enum.IKControlType.LookAt
    ikControl.ChainRoot = upperTorso
    ikControl.EndEffector = upperTorso
    ikControl.Target = ikTargetPart
    ikControl.Weight = 1
    ikControl.SmoothTime = 0.05
    ikControl.Parent = humanoid
end

if LocalPlayer.Character then
    setupIK(LocalPlayer.Character)
end
LocalPlayer.CharacterAdded:Connect(setupIK)

-- ==========================================
-- UI 생성
-- ==========================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "RivalsIkTest3Gui"
screenGui.Parent = (gethui and gethui()) or game:GetService("CoreGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 260, 0, 145)
mainFrame.Position = UDim2.new(0.05, 0, 0.3, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.BackgroundTransparency = 1
title.Text = "Test 3: IKControl + 100x Random"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextSize = 13
title.Font = Enum.Font.SourceSansBold
title.Parent = mainFrame

-- 모드 전환 버튼
local modeButton = Instance.new("TextButton")
modeButton.Size = UDim2.new(0.9, 0, 0, 24)
modeButton.Position = UDim2.new(0.05, 0, 0, 32)
modeButton.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
modeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
modeButton.TextSize = 12
modeButton.Font = Enum.Font.SourceSansBold
modeButton.Text = "Mode: Slider (-90° ~ 90°)"
modeButton.Parent = mainFrame

local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 4)
btnCorner.Parent = modeButton

-- 슬라이더 컨테이너
local sliderContainer = Instance.new("Frame")
sliderContainer.Size = UDim2.new(0.9, 0, 0, 50)
sliderContainer.Position = UDim2.new(0.05, 0, 0, 62)
sliderContainer.BackgroundTransparency = 1
sliderContainer.Parent = mainFrame

local sliderLabel = Instance.new("TextLabel")
sliderLabel.Size = UDim2.new(1, 0, 0, 18)
sliderLabel.BackgroundTransparency = 1
sliderLabel.Text = string.format("Pitch: %d°", pitchAngle)
sliderLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
sliderLabel.TextSize = 12
sliderLabel.Font = Enum.Font.SourceSans
sliderLabel.TextXAlignment = Enum.TextXAlignment.Center
sliderLabel.Parent = sliderContainer

local bgBar = Instance.new("TextButton")
bgBar.Size = UDim2.new(1, 0, 0, 12)
bgBar.Position = UDim2.new(0, 0, 0, 24)
bgBar.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
bgBar.AutoButtonColor = false
bgBar.Text = ""
bgBar.Parent = sliderContainer

local fillBar = Instance.new("Frame")
fillBar.Size = UDim2.new(0.5, 0, 1, 0)
fillBar.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
fillBar.BorderSizePixel = 0
fillBar.Parent = bgBar

-- 모드 전환 버튼 이벤트
modeButton.MouseButton1Click:Connect(function()
    isRandomMode = not isRandomMode
    if isRandomMode then
        modeButton.Text = "Mode: 100x Random (-100° ~ 100°)"
        modeButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
    else
        modeButton.Text = "Mode: Slider (-90° ~ 90°)"
        modeButton.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    end
end)

local dragging = false
local function updateInput(input)
    if isRandomMode then return end
    local pos = math.clamp((input.Position.X - bgBar.AbsolutePosition.X) / bgBar.AbsoluteSize.X, 0, 1)
    fillBar.Size = UDim2.new(pos, 0, 1, 0)
    pitchAngle = math.floor(-90 + (180 * pos))
    sliderLabel.Text = string.format("Pitch: %d°", pitchAngle)
end

bgBar.InputBegan:Connect(function(input)
    if not isRandomMode and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragging = true
        updateInput(input)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not isRandomMode and dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateInput(input)
    end
end)

-- ==========================================
-- 실시간 IK 타깃 위치 연산 및 100배 빠른 랜덤 모드
-- ==========================================
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    if char and ikTargetPart and ikControl then
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        
        if rootPart then
            -- 기존 속도(3)에 100을 곱해 300으로 설정하여 100배 빠르게 왕복
            if isRandomMode then
                pitchAngle = math.floor(math.sin(tick() * 300) * 100)
                sliderLabel.Text = string.format("100x Random Pitch: %d°", pitchAngle)
            end

            local rad = math.rad(pitchAngle)
            local dist = 10
            
            local basePos = rootPart.Position + Vector3.new(0, 1.5, 0)
            local lookDir = rootPart.CFrame.LookVector
            local upDir = rootPart.CFrame.UpVector
            
            local targetPos = basePos + (lookDir * (dist * math.cos(rad))) + (upDir * (dist * math.sin(rad)))
            ikTargetPart.Position = targetPos
        end
    end
end)
