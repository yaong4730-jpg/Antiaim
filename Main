local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- ==========================================
-- 1. 기존 GUI 정리
-- ==========================================
local GUI_NAME = "RivalsMonochromeGui"
local parentGui = (gethui and gethui()) or LocalPlayer:WaitForChild("PlayerGui")

if parentGui:FindFirstChild(GUI_NAME) then
    parentGui[GUI_NAME]:Destroy()
end

-- ==========================================
-- 2. 상태 변수 및 캐싱
-- ==========================================
local neckPitch = 0
local waistPitch = 0
local spinSpeed = 90
local isRandomMode = false
local isSpinMode = false
local isCamSync = false
local isClickTpMode = false
local isVoidSpamMode = false

local lastRandomTick = 0
local RANDOM_INTERVAL = 0.05

local char, hum, hrp, head, upperTorso, neck, waist
local origNeckC0, origWaistC0

local function setupCharacter(character)
    if not character then return end
    char = character
    hum = character:WaitForChild("Humanoid", 5)
    hrp = character:WaitForChild("HumanoidRootPart", 5)
    head = character:WaitForChild("Head", 5)
    upperTorso = character:WaitForChild("UpperTorso", 5)

    if not head or not upperTorso then return end

    neck = head:FindFirstChild("Neck")
    waist = upperTorso:FindFirstChild("Waist")

    if neck and not origNeckC0 then origNeckC0 = neck.C0 end
    if waist and not origWaistC0 then origWaistC0 = waist.C0 end

    if hum and isSpinMode then
        hum.AutoRotate = false
    end
end

if LocalPlayer.Character then setupCharacter(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(setupCharacter)

-- ==========================================
-- 3. 모노크롬 UI 생성
-- ==========================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = GUI_NAME
screenGui.ResetOnSpawn = false
screenGui.Parent = parentGui

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 260, 0, 420)
mainFrame.Position = UDim2.new(0.05, 0, 0.25, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15) -- 딥 블랙
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 6)
corner.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 32)
title.BackgroundTransparency = 1
title.Text = "MONOCHROME CONTROL"
title.TextColor3 = Color3.fromRGB(240, 240, 240)
title.TextSize = 11
title.Font = Enum.Font.GothamBold
title.Parent = mainFrame

-- 창 드래그
local draggingWindow, dragStart, startPos
title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingWindow = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

-- 버튼 생성 함수 (모노크롬 스타일)
local function createButton(text, yPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 28)
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30) -- 다크 그레이
    btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamSemibold
    btn.Text = text
    btn.Parent = mainFrame

    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 4)
    btnCorner.Parent = btn
    return btn
end

-- 슬라이더 생성 함수 (모노크롬 스타일)
local function createSlider(yPos, labelText, defaultRatio)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.9, 0, 0, 42)
    container.Position = UDim2.new(0.05, 0, 0, yPos)
    container.BackgroundTransparency = 1
    container.Parent = mainFrame

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 16)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(180, 180, 180)
    label.TextSize = 10
    label.Font = Enum.Font.Gotham
    label.Parent = container

    local bgBar = Instance.new("Frame")
    bgBar.Size = UDim2.new(1, 0, 0, 8)
    bgBar.Position = UDim2.new(0, 0, 0, 20)
    bgBar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    bgBar.BorderSizePixel = 0
    bgBar.Parent = container

    local bgCorner = Instance.new("UICorner")
    bgCorner.CornerRadius = UDim.new(1, 0)
    bgCorner.Parent = bgBar

    local fillBar = Instance.new("Frame")
    fillBar.Size = UDim2.new(defaultRatio, 0, 1, 0)
    fillBar.BackgroundColor3 = Color3.fromRGB(240, 240, 240) -- 화이트 Fill
    fillBar.BorderSizePixel = 0
    fillBar.Parent = bgBar

    local fillCorner = Instance.new("UICorner")
    fillCorner.CornerRadius = UDim.new(1, 0)
    fillCorner.Parent = fillBar

    local trigger = Instance.new("TextButton")
    trigger.Size = UDim2.new(1, 0, 1, 8)
    trigger.Position = UDim2.new(0, 0, 0, -4)
    trigger.BackgroundTransparency = 1
    trigger.Text = ""
    trigger.Parent = bgBar

    return trigger, bgBar, fillBar, label
end

-- UI 요소 배치
local randomButton = createButton("Waist Random: OFF", 38)
local spinButton = createButton("Body Spin Mode: OFF", 70)
local camSyncButton = createButton("Camera Sync: OFF", 102)
local clickTpButton = createButton("Click TP: OFF", 134)
local voidSpamButton = createButton("Void Spam: OFF", 166)

local neckTrig, neckBg, neckFill, neckLbl = createSlider(204, "Neck Pitch: 0°", 0.5)
local waistTrig, waistBg, waistFill, waistLbl = createSlider(252, "Waist Pitch: 0°", 0.5)
local spinTrig, spinBg, spinFill, spinLbl = createSlider(300, "Spin Speed: 90", 0.5)

-- ==========================================
-- 4. 이벤트 핸들러 (반전 화이트/블랙 토글 디자인)
-- ==========================================
local function updateButtonStyle(btn, state)
    if state then
        btn.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
        btn.TextColor3 = Color3.fromRGB(15, 15, 15)
    else
        btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        btn.TextColor3 = Color3.fromRGB(220, 220, 220)
    end
end

randomButton.MouseButton1Click:Connect(function()
    isRandomMode = not isRandomMode
    randomButton.Text = "Waist Random: " .. (isRandomMode and "ON" or "OFF")
    updateButtonStyle(randomButton, isRandomMode)
end)

spinButton.MouseButton1Click:Connect(function()
    isSpinMode = not isSpinMode
    spinButton.Text = "Body Spin Mode: " .. (isSpinMode and "ON" or "OFF")
    updateButtonStyle(spinButton, isSpinMode)
    if hum then hum.AutoRotate = not isSpinMode end
end)

camSyncButton.MouseButton1Click:Connect(function()
    isCamSync = not isCamSync
    camSyncButton.Text = "Camera Sync: " .. (isCamSync and "ON" or "OFF")
    updateButtonStyle(camSyncButton, isCamSync)
    
    local cam = workspace.CurrentCamera
    if not isCamSync then
        cam.CameraType = Enum.CameraType.Custom
        if hum then cam.CameraSubject = hum end
    end
end)

clickTpButton.MouseButton1Click:Connect(function()
    isClickTpMode = not isClickTpMode
    clickTpButton.Text = "Click TP: " .. (isClickTpMode and "ON" or "OFF")
    updateButtonStyle(clickTpButton, isClickTpMode)
end)

voidSpamButton.MouseButton1Click:Connect(function()
    isVoidSpamMode = not isVoidSpamMode
    voidSpamButton.Text = "Void Spam: " .. (isVoidSpamMode and "ON" or "OFF")
    updateButtonStyle(voidSpamButton, isVoidSpamMode)
end)

Mouse.Button1Down:Connect(function()
    if isClickTpMode and hrp and hrp.Parent and Mouse.Target then
        local hitPos = Mouse.Hit.Position
        hrp.CFrame = CFrame.new(hitPos + Vector3.new(0, 3, 0))
    end
end)

local activeSlider = nil
local function registerSlider(trigger, bg, fill, label, minVal, maxVal, callback)
    trigger.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            activeSlider = { bg = bg, fill = fill, label = label, min = minVal, max = maxVal, cb = callback }
            local relX = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            fill.Size = UDim2.new(relX, 0, 1, 0)
            local val = math.floor(minVal + (maxVal - minVal) * relX)
            callback(val, label)
        end
    end)
end

registerSlider(neckTrig, neckBg, neckFill, neckLbl, -180, 180, function(val, lbl)
    neckPitch = val
    lbl.Text = string.format("Neck Pitch: %d°", val)
end)

registerSlider(waistTrig, waistBg, waistFill, waistLbl, -180, 180, function(val, lbl)
    if not isRandomMode then
        waistPitch = val
        lbl.Text = string.format("Waist Pitch: %d°", val)
    end
end)

registerSlider(spinTrig, spinBg, spinFill, spinLbl, 0, 180, function(val, lbl)
    spinSpeed = val
    lbl.Text = string.format("Spin Speed: %d", val)
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        if draggingWindow then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        elseif activeSlider then
            local relX = math.clamp((input.Position.X - activeSlider.bg.AbsolutePosition.X) / activeSlider.bg.AbsoluteSize.X, 0, 1)
            activeSlider.fill.Size = UDim2.new(relX, 0, 1, 0)
            local val = math.floor(activeSlider.min + (activeSlider.max - activeSlider.min) * relX)
            activeSlider.cb(val, activeSlider.label)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingWindow = false
        activeSlider = nil
    end
end)

-- ==========================================
-- 5. 가벼운 렌더링 루프 (Void Spam -10000 유지)
-- ==========================================
RunService.RenderStepped:Connect(function(dt)
    if not char or not char.Parent or not hrp or not hrp.Parent then return end

    if isVoidSpamMode then
        hrp.CFrame = CFrame.new(hrp.Position.X, -10000, hrp.Position.Z)
    end

    if isSpinMode then
        local rotRad = math.rad(spinSpeed * (dt * 60))
        hrp.CFrame = hrp.CFrame * CFrame.Angles(0, rotRad, 0)
    end

    if neck and origNeckC0 then
        neck.C0 = CFrame.new(origNeckC0.Position) * CFrame.fromAxisAngle(Vector3.xAxis, math.rad(neckPitch))
        neck.Transform = CFrame.new()
    end

    if waist and origWaistC0 then
        if isRandomMode then
            local now = tick()
            if now - lastRandomTick >= RANDOM_INTERVAL then
                lastRandomTick = now
                waistPitch = math.random(-180, 180)
            end
        end
        waist.C0 = CFrame.new(origWaistC0.Position) * CFrame.fromAxisAngle(Vector3.xAxis, math.rad(waistPitch))
        waist.Transform = CFrame.new()
    end

    if isCamSync and head and head.Parent then
        local cam = workspace.CurrentCamera
        cam.CameraType = Enum.CameraType.Scriptable
        cam.CFrame = head.CFrame * CFrame.new(0, 1.5, 8) 
    end
end)
