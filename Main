local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local utility = require(ReplicatedStorage.Modules.Utility)
local cameraController = require(player.PlayerScripts.Controllers.CameraController)

local updateRotation = ReplicatedStorage.Remotes.Replication.Fighter.UpdateCameraRotation

-- 기존 GUI 정리
if game:GetService("CoreGui"):FindFirstChild("RivalsRemoteTestGui") then
    game:GetService("CoreGui").RivalsRemoteTestGui:Destroy()
end

local pitchAngle = 0
local isRandomMode = false
local lastRandomTick = 0
local randomInterval = 0.05 -- 0.05초 텀

-- 스레드 중복 실행 방지
_G.CameraRotationThread = (_G.CameraRotationThread or 0) + 1
local thread = _G.CameraRotationThread

-- 서버로 회전 데이터 전송 루프 (FE 동기화)
task.spawn(function()
    while thread == _G.CameraRotationThread do
        local rotation = cameraController.Rotation
        local yaw = rotation and rotation.Y or 0

        if isRandomMode then
            local currentTick = tick()
            if currentTick - lastRandomTick >= randomInterval then
                lastRandomTick = currentTick
                pitchAngle = math.random(-150, 150) -- -150도 ~ 150도 랜덤 TP
            end
        end

        pcall(function()
            updateRotation:FireServer(
                utility:EncodeCameraRotation(Vector2.new(math.rad(pitchAngle), yaw)),
                nil
            )
        end)

        task.wait()
    end
end)

-- ==========================================
-- UI 생성 (슬라이더 및 모드 전환)
-- ==========================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "RivalsRemoteTestGui"
screenGui.Parent = (gethui and gethui()) or game:GetService("CoreGui")

local mainFrame = Instance.new("Frame")
mainFrame.Size = UDim2.new(0, 260, 0, 145)
mainFrame.Position = UDim2.new(0.05, 0, 0.3, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
mainFrame.BorderSizePixel = 0
mainFrame.Active = true
mainFrame.Draggable = true
mainFrame.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = mainFrame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.BackgroundTransparency = 1
title.Text = "Rivals FE Remote Sync"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.TextSize = 12
title.Font = Enum.Font.SourceSansBold
title.Parent = mainFrame

-- 모드 전환 버튼
local modeButton = Instance.new("TextButton")
modeButton.Size = UDim2.new(0.9, 0, 0, 24)
modeButton.Position = UDim2.new(0.05, 0, 0, 32)
modeButton.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
modeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
modeButton.TextSize = 12
modeButton.Font = Enum.Font.SourceSansBold
modeButton.Text = "Mode: Slider (-150° ~ 150°)"
modeButton.Parent = mainFrame

local btnCorner = Instance.new("UICorner")
btnCorner.CornerRadius = UDim.new(0, 4)
btnCorner.Parent = modeButton

-- 슬라이더 컨테이너
local sliderContainer = Instance.new("Frame")
sliderContainer.Size = UDim2.new(0.9, 0, 0, 50)
sliderContainer.Position = UDim2.new(0.05, 0, 0, 62)
sliderContainer.BackgroundTransparency = 1
sliderContainer.Parent = mainFrame

local sliderLabel = Instance.new("TextLabel")
sliderLabel.Size = UDim2.new(1, 0, 0, 18)
sliderLabel.BackgroundTransparency = 1
sliderLabel.Text = string.format("Pitch: %d°", pitchAngle)
sliderLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
sliderLabel.TextSize = 12
sliderLabel.Font = Enum.Font.SourceSans
sliderLabel.TextXAlignment = Enum.TextXAlignment.Center
sliderLabel.Parent = sliderContainer

local bgBar = Instance.new("TextButton")
bgBar.Size = UDim2.new(1, 0, 0, 12)
bgBar.Position = UDim2.new(0, 0, 0, 24)
bgBar.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
bgBar.AutoButtonColor = false
bgBar.Text = ""
bgBar.Parent = sliderContainer

local fillBar = Instance.new("Frame")
fillBar.Size = UDim2.new(0.5, 0, 1, 0)
fillBar.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
fillBar.BorderSizePixel = 0
fillBar.Parent = bgBar

-- 모드 전환 버튼 이벤트
modeButton.MouseButton1Click:Connect(function()
    isRandomMode = not isRandomMode
    if isRandomMode then
        modeButton.Text = "Mode: TP Random (0.05s, ±150°)"
        modeButton.BackgroundColor3 = Color3.fromRGB(0, 120, 200)
    else
        modeButton.Text = "Mode: Slider (-150° ~ 150°)"
        modeButton.BackgroundColor3 = Color3.fromRGB(60, 60, 75)
    end
end)

local dragging = false
local function updateInput(input)
    if isRandomMode then return end
    local pos = math.clamp((input.Position.X - bgBar.AbsolutePosition.X) / bgBar.AbsoluteSize.X, 0, 1)
    fillBar.Size = UDim2.new(pos, 0, 1, 0)
    pitchAngle = math.floor(-150 + (300 * pos))
    sliderLabel.Text = string.format("Pitch: %d°", pitchAngle)
end

bgBar.InputBegan:Connect(function(input)
    if not isRandomMode and (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then
        dragging = true
        updateInput(input)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if not isRandomMode and dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        updateInput(input)
    end
end)
